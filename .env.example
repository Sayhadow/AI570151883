# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
API_BODY_LIMIT=10mb
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database
POSTGRES_USER=ai_image
POSTGRES_PASSWORD=ai_image_dev
POSTGRES_DB=ai_image
DATABASE_URL=postgresql://ai_image:ai_image_dev@localhost:5432/ai_image?schema=public

# Redis
# Use REDIS_QUEUE_URL for BullMQ jobs and RATE_LIMIT_REDIS_URL for lightweight limits.
# REDIS_URL is kept as a local fallback when the two dedicated URLs are not set.
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379
RATE_LIMIT_REDIS_URL=redis://localhost:6379
GENERATION_QUEUE_NAME=generation
GENERATION_DEFAULT_POINT_COST=10
WORKER_CONCURRENCY=2
PROVIDER_IMAGE_CONCURRENCY=2

# Object storage
ASSET_STORAGE_DRIVER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=ai-image-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Auth
SESSION_SECRET=change-me-in-local-env
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345
SEED_ADMIN_POINTS=1000
SEED_INVITE_CODE=INTERNAL-TEST-2026

# AI provider
AI_PROVIDER=mock
MOCK_PROVIDER_DELAY_MS=2500
MOCK_PROVIDER_IMAGE_STAGGER_MS=150
GENERATED_ASSET_DIR=.generated-assets

# OpenAI-compatible third-party image relay
THIRD_PARTY_IMAGE_API_BASE_URL=
THIRD_PARTY_IMAGE_API_KEY=
THIRD_PARTY_IMAGE_MODEL=gpt-image-1
THIRD_PARTY_IMAGE_API_PATH=/v1/images/generations
THIRD_PARTY_IMAGE_TASK_PATH=/v1/tasks
PROVIDER_TASK_INITIAL_DELAY_MS=12000
PROVIDER_TASK_POLL_INTERVAL_MS=5000
PROVIDER_TASK_MAX_ATTEMPTS=120

# Optional separate provider slots
PROVIDER_A_BASE_URL=
PROVIDER_A_API_KEY=
PROVIDER_A_MODEL=
PROVIDER_A_IMAGE_PATH=/v1/images/generations
PROVIDER_A_TASK_PATH=/v1/tasks
PROVIDER_B_BASE_URL=
PROVIDER_B_API_KEY=
PROVIDER_B_MODEL=
PROVIDER_B_IMAGE_PATH=/v1/images/generations
PROVIDER_B_TASK_PATH=/v1/tasks
