{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ai-image/shared": ["packages/shared/src/index.ts"],
      "@ai-image/db": ["packages/db/src/index.ts"],
      "@ai-image/storage": ["packages/storage/src/index.ts"]
    }
  }
}
