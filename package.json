{
  "name": "ai-image-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel dev",
    "dev:web": "corepack pnpm --filter @ai-image/web dev",
    "dev:api": "corepack pnpm --filter @ai-image/api dev",
    "dev:worker": "corepack pnpm --filter @ai-image/worker dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "db:generate": "corepack pnpm --filter @ai-image/db db:generate",
    "db:migrate": "corepack pnpm --filter @ai-image/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
